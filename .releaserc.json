{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",

    [
      "@semantic-release/exec",
      {
        "prepareCmd": "pwsh ./scripts/update-version.ps1 ${nextRelease.version}"
      }
    ],

    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "release/**",
            "label": "Windows Build"
          }
        ]
      }
    ]
  ]
}